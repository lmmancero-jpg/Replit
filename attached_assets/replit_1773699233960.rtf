\pard\pardeftab720\partightenfactor0

\f1\b\fs48 \cf2 1.1 No romper lo existente
\f2\b0\fs32 \
\pard\pardeftab720\partightenfactor0
\ls3\ilvl0
\f0 \cf2 {\listtext	\uc0\u8226 	}No cambies nombres, estructura, c\'e1lculos ni dise\'f1o de 2.0, 2.1 y 2.2, salvo que sea necesario para mantener consistencia visual.
\f2 \
\ls3\ilvl0
\f0 {\listtext	\uc0\u8226 	}No alteres c\'e1lculos actuales de costos fijos, variables, administrativos, depreciaci\'f3n, etc.
\f2 \
\ls3\ilvl0
\f0 {\listtext	\uc0\u8226 	}No elimines ninguna funcionalidad existente.
\f2 \
\pard\pardeftab720\partightenfactor0

\f0 \cf2 \'a0
\f2 \
\pard\pardeftab720\partightenfactor0

