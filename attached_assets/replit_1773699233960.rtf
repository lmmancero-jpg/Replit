\f1\b\fs48 \cf2 4.1 IVA
\f2\b0\fs32 \
\pard\pardeftab720\partightenfactor0

\f0 \cf2 \'a0
\f2 \

\f0 El precio de Petroecuador viene con IVA y se debe 
\f1\b descontar el 15%
\f0\b0 .
\f2 \

\f0 \'a0
\f2 \

\f0 No debes restar 15% directamente.
\f2 \

\f0 Debes convertir el precio con IVA a precio neto as\'ed:
\f2 \

\f0 \'a0
\f2 \

\f0 precio_neto = precio_con_iva / 1.15
\f2 \

\f0 \'a0
\f2 \

\f0 Esto aplica a:
\f2 \
\pard\pardeftab720\partightenfactor0
\ls11\ilvl0
\f0 \cf2 {\listtext	\uc0\u8226 	}HFO per\'edodo 1
\f2 \
\ls11\ilvl0
\f0 {\listtext	\uc0\u8226 	}HFO per\'edodo 2
\f2 \
\ls11\ilvl0
\f0 {\listtext	\uc0\u8226 	}di\'e9sel per\'edodo 1
\f2 \
\ls11\ilvl0
\f0 {\listtext	\uc0\u8226 	}di\'e9sel per\'edodo 2
\f2 \
\pard\pardeftab720\partightenfactor0

\f0 \cf2 \'a0
\f2 \
