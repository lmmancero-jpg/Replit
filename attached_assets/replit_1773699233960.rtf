\ls12\ilvl0
\f0 \cf2 {\listtext	\uc0\u8226 	}430 USD por cada 9898 galones
\f2 \
\pard\pardeftab720\partightenfactor0

\f0 \cf2 \'a0
\f2 \

\f0 Costo unitario transporte HFO:
\f2 \

\f0 430 / 9898 USD/gal\'f3n
\f2 \

\f0 \'a0
