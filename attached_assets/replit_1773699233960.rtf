\f1\b\fs36 \cf2 Variables constantes
\f2\b0\fs32 \
\pard\pardeftab720\partightenfactor0

\f0 \cf2 \'a0
\f2 \

\f0 Usa estas constantes:
\f2 \
\pard\pardeftab720\partightenfactor0

\f3\fs26\fsmilli13333 \cf2 const VAT_RATE = 0.15;
\f2\fs32 \

\f3\fs26\fsmilli13333 const HFO_FREIGHT_PER_GAL = 430 / 9898;
\f2\fs32 \

\f3\fs26\fsmilli13333 const DIESEL_FREIGHT_PER_GAL = 100 / 2000;
\f2\fs32 \
\pard\pardeftab720\partightenfactor0

\f1\b\fs36 \cf2 Funci\'f3n para quitar IVA
\f2\b0\fs32 \
\pard\pardeftab720\partightenfactor0

\f3\fs26\fsmilli13333 \cf2 function removeVat(priceWithVat) \{
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 return priceWithVat / (1 + VAT_RATE);
\f2\fs32 \

\f3\fs26\fsmilli13333 \}
\f2\fs32 \
\pard\pardeftab720\partightenfactor0

\f1\b\fs36 \cf2 Costo neto de combustible
\f2\b0\fs32 \
\pard\pardeftab720\partightenfactor0

\f0 \cf2 \'a0
\f2 \

\f0 Debes calcular:
\f2 \
\pard\pardeftab720\partightenfactor0

\f3\fs26\fsmilli13333 \cf2 const hfoNetP1 = removeVat(hfoPriceP1WithVat);
\f2\fs32 \

\f3\fs26\fsmilli13333 const hfoNetP2 = removeVat(hfoPriceP2WithVat);
\f2\fs32 \

\f3\fs26\fsmilli13333 const dieselNetP1 = removeVat(dieselPriceP1WithVat);
\f2\fs32 \

\f3\fs26\fsmilli13333 const dieselNetP2 = removeVat(dieselPriceP2WithVat);
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0
\f2\fs32 \

\f3\fs26\fsmilli13333 const hfoCostP1 = hfoGallonsP1 * hfoNetP1;
\f2\fs32 \

\f3\fs26\fsmilli13333 const hfoCostP2 = hfoGallonsP2 * hfoNetP2;
\f2\fs32 \

\f3\fs26\fsmilli13333 const dieselCostP1 = dieselGallonsP1 * dieselNetP1;
\f2\fs32 \

\f3\fs26\fsmilli13333 const dieselCostP2 = dieselGallonsP2 * dieselNetP2;
\f2\fs32 \
\pard\pardeftab720\partightenfactor0

\f1\b\fs36 \cf2 Costo de transporte
\f2\b0\fs32 \
\pard\pardeftab720\partightenfactor0

\f3\fs26\fsmilli13333 \cf2 const hfoFreight = (hfoGallonsP1 + hfoGallonsP2) * HFO_FREIGHT_PER_GAL;
\f2\fs32 \

\f3\fs26\fsmilli13333 const dieselFreight = (dieselGallonsP1 + dieselGallonsP2) * DIESEL_FREIGHT_PER_GAL;
\f2\fs32 \
\pard\pardeftab720\partightenfactor0

\f1\b\fs36 \cf2 Totales
\f2\b0\fs32 \
\pard\pardeftab720\partightenfactor0

\f3\fs26\fsmilli13333 \cf2 const totalHfoCost = hfoCostP1 + hfoCostP2 + hfoFreight;
\f2\fs32 \

\f3\fs26\fsmilli13333 const totalDieselCost = dieselCostP1 + dieselCostP2 + dieselFreight;
\f2\fs32 \

\f3\fs26\fsmilli13333 const totalFuelCost = totalHfoCost + totalDieselCost;
\f2\fs32 \
\pard\pardeftab720\partightenfactor0

\f1\b\fs36 \cf2 Precio real de producci\'f3n
\f2\b0\fs32 \
\pard\pardeftab720\partightenfactor0

\f0 \cf2 \'a0
\f2 \

\f0 Debes dividir el costo total real del combustible para la energ\'eda base del per\'edodo.
\f2 \
\pard\pardeftab720\partightenfactor0

\f3\fs26\fsmilli13333 \cf2 const realProductionPrice = totalFuelCost / energyKwh;
\f2\fs32 \
\pard\pardeftab720\partightenfactor0

\f0 \cf2 Usa como denominador la 
\f1\b energ\'eda del per\'edodo del reporte
\f0\b0  que la app ya usa como base principal del informe. No alteres el resto de indicadores actuales.
\f2 \

\f0 \'a0
\f2 \
\pard\pardeftab720\partightenfactor0

