\f3\fs26\fsmilli13333 \cf2 function calculateRealFuelProductionCost(\{
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 hfoGallonsP1,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 hfoGallonsP2,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 dieselGallonsP1,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 dieselGallonsP2,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 hfoPriceP1WithVat,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 hfoPriceP2WithVat,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 dieselPriceP1WithVat,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 dieselPriceP2WithVat,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 energyKwh
\f2\fs32 \

\f3\fs26\fsmilli13333 \}) \{
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const VAT_RATE = 0.15;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const HFO_FREIGHT_PER_GAL = 430 / 9898;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const DIESEL_FREIGHT_PER_GAL = 100 / 2000;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const removeVat = (priceWithVat) => priceWithVat / (1 + VAT_RATE);
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const hfoNetP1 = removeVat(hfoPriceP1WithVat);
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const hfoNetP2 = removeVat(hfoPriceP2WithVat);
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const dieselNetP1 = removeVat(dieselPriceP1WithVat);
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const dieselNetP2 = removeVat(dieselPriceP2WithVat);
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const hfoCostP1 = hfoGallonsP1 * hfoNetP1;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const hfoCostP2 = hfoGallonsP2 * hfoNetP2;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const dieselCostP1 = dieselGallonsP1 * dieselNetP1;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const dieselCostP2 = dieselGallonsP2 * dieselNetP2;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const hfoFreight = (hfoGallonsP1 + hfoGallonsP2) * HFO_FREIGHT_PER_GAL;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const dieselFreight = (dieselGallonsP1 + dieselGallonsP2) * DIESEL_FREIGHT_PER_GAL;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const totalHfoCost = hfoCostP1 + hfoCostP2 + hfoFreight;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const totalDieselCost = dieselCostP1 + dieselCostP2 + dieselFreight;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const totalFuelCost = totalHfoCost + totalDieselCost;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 const realProductionPrice = energyKwh > 0 ? totalFuelCost / energyKwh : 0;
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 return \{
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 hfoNetP1,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 hfoNetP2,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 dieselNetP1,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 dieselNetP2,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 hfoCostP1,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 hfoCostP2,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 dieselCostP1,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 dieselCostP2,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 hfoFreight,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 dieselFreight,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 totalHfoCost,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 totalDieselCost,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 totalFuelCost,
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0\'a0\'a0 realProductionPrice
\f2\fs32 \

\f3\fs26\fsmilli13333 \'a0 \};
\f2\fs32 \

\f3\fs26\fsmilli13333 \}
\f2\fs32 \
\pard\pardeftab720\partightenfactor0

