\f1\b\fs36 \cf2 Di\'e9sel
\f2\b0\fs32 \
\pard\pardeftab720\partightenfactor0
\ls13\ilvl0
\f0 \cf2 {\listtext	\uc0\u8226 	}100 USD por cada 2000 galones
\f2 \
\pard\pardeftab720\partightenfactor0

\f0 \cf2 \'a0
\f2 \

\f0 Costo unitario transporte di\'e9sel:
\f2 \

\f0 100 / 2000 USD/gal\'f3n
